# Normalize line endings to LF on commit (cross-platform consistency)
* text=auto eol=lf

# Explicitly set binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Keep these as-is
package-lock.json text eol=lf
